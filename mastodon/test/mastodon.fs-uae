# Mastodon on the Amiga - in-guest test config (FS-UAE 3.1.66 + AROS m68k)
# Boots the open-source AROS m68k ROM (no commercial Kickstart) and auto-runs
# the mastodon client from shared/S/startup-sequence against a host mock
# proxy bridge (mastodon_amiga_proxy.py --mock).
#
# Driven by run_test.sh (starts Xvfb :82 + the mock proxy on 0.0.0.0:8812,
# boots headless, screenshots, checks shared/masto.log).
#
# PARALLELISM: this config/port pair (Xvfb :82, proxy port 8812) is reserved
# for this test only - other concurrent agents use other displays/ports.
[fs-uae]

# A4000/040: AROS m68k boots on 68020+; 32-bit addressing for Zorro III RAM.
amiga_model = A4000/040

# AROS m68k Kickstart replacement (open source). Shared with the miner env.
kickstart_file = /home/scott/rustchain-amiga/emu/roms/aros-amiga-m68k-rom.bin
kickstart_ext_file = /home/scott/rustchain-amiga/emu/roms/aros-amiga-m68k-ext.bin

chip_memory = 2048
zorro_iii_memory = 32768

# bsdsocket.library emulation: guest socket calls run as host sockets, so the
# guest shares the host network identity and 127.0.0.1 reaches the host mock
# proxy. This is the client's network path in --proxy mode.
bsdsocket_library = 1

# Boot volume: this test's shared directory, mounted as DH0:/SYS:. Holds the
# mastodon binary, the token fixture, and S/startup-sequence; masto.log is
# written here (host-visible).
hard_drive_0 = /home/scott/rustchain-amiga/mastodon/test/shared
hard_drive_0_label = Mastodon

fullscreen = 0
initial_input_grab = 0
automatic_input_grab = 0
floppy_drive_volume = 0
screenshots_output_dir = /home/scott/rustchain-amiga/mastodon/test/screenshots
