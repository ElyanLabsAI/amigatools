# Amiga MCP server - in-guest test config (FS-UAE + AROS m68k)
# Boots the open-source AROS m68k ROM (no commercial Kickstart) and auto-runs
# the MCP server from shared/S/startup-sequence, driving it over stdio via
# AmigaDOS redirection (stdin from requests.txt, stdout to responses.txt).
#
# This is STDIO, not networking - no bsdsocket needed.
# Driven by run_test.sh (boots headless on Xvfb :84, checks output files).
[fs-uae]

# A4000/040: AROS m68k boots on 68020+; 32-bit addressing for Zorro III RAM.
amiga_model = A4000/040

# AROS m68k Kickstart replacement (open source). Shared with the miner env.
kickstart_file = /home/scott/rustchain-amiga/emu/roms/aros-amiga-m68k-rom.bin
kickstart_ext_file = /home/scott/rustchain-amiga/emu/roms/aros-amiga-m68k-ext.bin

chip_memory = 2048
zorro_iii_memory = 32768

# Boot volume: this test's shared directory, mounted as DH0:/SYS:. Holds the
# mcp-amiga binary, requests.txt and S/startup-sequence; the server writes
# responses.txt and mcp_touched.txt here (host-visible).
hard_drive_0 = /home/scott/rustchain-amiga/mcp/test/shared
hard_drive_0_label = MCP

fullscreen = 0
initial_input_grab = 0
automatic_input_grab = 0
floppy_drive_volume = 0
screenshots_output_dir = /home/scott/rustchain-amiga/mcp/test/screenshots
