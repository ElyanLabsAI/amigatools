# narrator say - in-guest test config (FS-UAE + AROS m68k ROM)
# Boots the open-source AROS m68k ROM and auto-runs narrator/bin/say from
# shared/S/startup-sequence. Driven by run_test.sh (headless on Xvfb :85).
#
# Manual run:
#   xvfb-run -a -s "-screen 0 1024x768x24" fs-uae narrator.fs-uae
[fs-uae]

# A4000/040: AROS m68k boots on 68020+; 32-bit addressing for Zorro III RAM.
amiga_model = A4000/040

# AROS m68k Kickstart replacement (open source).
kickstart_file = /home/scott/rustchain-amiga/emu/roms/aros-amiga-m68k-rom.bin
kickstart_ext_file = /home/scott/rustchain-amiga/emu/roms/aros-amiga-m68k-ext.bin

chip_memory = 2048
zorro_iii_memory = 32768

# Boot volume: this test's shared directory, mounted as DH0:/SYS:. Holds the
# say binary and S/startup-sequence; say.log is written here (host-visible).
hard_drive_0 = /home/scott/rustchain-amiga/narrator/test/shared
hard_drive_0_label = Narrator

fullscreen = 0
initial_input_grab = 0
automatic_input_grab = 0
floppy_drive_volume = 0
screenshots_output_dir = /home/scott/rustchain-amiga/narrator/test/screenshots
